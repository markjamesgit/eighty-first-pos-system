rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function clientId() {
      return request.auth.token.clientId;
    }

    function isSuperAdmin() {
      return isSignedIn() && role() == "super_admin";
    }

    function isClientUser() {
      return isSignedIn() && (role() == "client_admin" || role() == "cashier" || role() == "admin");
    }

    function sameClient(res) {
      return res != null && res.data != null && (res.data.clientId == clientId() || !("clientId" in res.data));
    }

    function sameClientOrGlobal(res) {
       // Allow if document has no clientId (global) or matches user's clientId
       return res == null || res.data == null || res.data.clientId == null || res.data.clientId == clientId();
    }

    // Default: allow everything for Super Admin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Specific rules for other roles
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
    }

    // Application Data Scoping
    match /products/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /ingredients/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /orders_active/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /orders_history/{docId} {
      allow read, write: if isClientUser();
    }

    match /sales_summary/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /alerts/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /product_recipes/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /maintenance_categories/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /maintenance_variants/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /maintenance_addons/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /maintenance_modifiers/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow create: if isClientUser() && sameClient(request.resource);
      allow update, delete: if isClientUser() && sameClient(resource);
    }

    match /stock_history/{docId} {
      allow read, write: if isClientUser();
    }

    match /ingredient_stock_history/{docId} {
      allow read, write: if isClientUser();
    }

    match /audit_trail/{docId} {
      allow read, write: if isClientUser();
    }

    match /alert_emails/{docId} {
      allow read, write: if isClientUser();
    }

    match /mail/{docId} {
      allow read, write: if isClientUser();
    }

    match /transactions/{docId} {
      allow read, write: if isClientUser();
    }

    match /admin_config/{docId} {
      allow read: if isClientUser() && sameClientOrGlobal(resource);
      allow write: if isClientUser() && docId == clientId();
    }

    match /clients/{docId} {
      allow read: if isClientUser() && docId == clientId();
    }
  }
}

